{
  "expo": {
    "name": "True Tilawah",
    "slug": "true-tilawah",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1A3C34"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.truetilawah.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "True Tilawah needs microphone access for Quranic recitation analysis.",
        "NSSpeechRecognitionUsageDescription": "True Tilawah uses speech recognition to analyze your recitation."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A3C34"
      },
      "package": "com.truetilawah.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET"
      ]
    },
    "web": {},
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "Allow True Tilawah to access your microphone for recitation."
        }
      ]
    ],
    "scheme": "truetilawah",
    "sdkVersion": "54.0.0",
    "extra": {}
  }
}
